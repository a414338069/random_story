# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-key-here          # DeepSeek API 密钥
DEEPSEEK_MODEL=deepseek-v4-flash            # 使用的模型（默认: deepseek-v4-flash）
DEEPSEEK_BASE_URL=https://api.deepseek.com  # API 基础地址

# 数据库配置
DATABASE_PATH=data/game.db                  # SQLite 数据库路径

# CORS 配置
CORS_ORIGINS=*                              # 允许的跨域来源（MVP 阶段允许所有）

# 游戏逻辑配置
MAX_EVENTS_PER_GAME=60                      # 每局游戏最大事件数（默认: 60）
CACHE_TTL=1800                              # AI 缓存 TTL（秒，默认: 1800）
